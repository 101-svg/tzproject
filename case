-- OBBY FARM
-- ============================================================
local obbyFarming  = false
local obbyThread   = nil
local obbyEarned   = 0
local obbyRuns     = 0
local rewardConn   = nil

local function stopObby()
    obbyFarming = false
    if obbyThread then task.cancel(obbyThread) obbyThread = nil end
    obbyStartBtn.Text = "START OBBY FARM"
    tween(obbyStartBtn, {BackgroundColor3 = C.green}, 0.3)
    obbyStepLbl.Text = "Stopped"
    obbyFill.Size    = UDim2.new(0,0,1,0)
end

local function startObby()
    obbyFarming = true
    obbyRuns    = 0
    obbyStartBtn.Text = "STOP OBBY FARM"
    tween(obbyStartBtn, {BackgroundColor3 = C.red}, 0.3)
    addLog(obbyLog2, "Obby farm started", C.green)

    local notifyR = RS:FindFirstChild("Remotes") and RS.Remotes:FindFirstChild("Notify")
    if notifyR then
        if rewardConn then rewardConn:Disconnect() end
        rewardConn = notifyR.OnClientEvent:Connect(function(msg)
            if type(msg)=="string" and msg:lower():find("obby") then
                obbyEarned += 5
                earnedVal.Text = "$"..obbyEarned
                addLog(obbyLog2, "$5 reward! Total $"..obbyEarned, C.gold)
                updateBalance()
            end
        end)
    end

    obbyThread = task.spawn(function()
        local total = #CHECKPOINTS
        while obbyFarming do
            obbyRuns += 1
            runsVal.Text = tostring(obbyRuns)
            addLog(obbyLog2, "Run #"..obbyRuns.." started", C.accent)

            for i, cp in ipairs(CHECKPOINTS) do
                if not obbyFarming then break end
                local char = player.Character
                local hrp  = char and char:FindFirstChild("HumanoidRootPart")
                if hrp then hrp.CFrame = CFrame.new(cp.pos + Vector3.new(0,3,0)) end
                local pct = i/total
                tween(obbyFill, {Size=UDim2.new(pct,0,1,0)}, STEP_DELAY*0.8)
                obbyStepLbl.Text = "Checkpoint "..cp.name.." / "..total
                obbyPctLbl.Text  = math.floor(pct*100).."%"
                task.wait(STEP_DELAY)
            end

            if obbyFarming then
                obbyFill.Size    = UDim2.new(1,0,1,0)
                obbyStepLbl.Text = "Waiting for reset..."
                obbyPctLbl.Text  = "done"
                task.wait(LOOP_DELAY)
                obbyFill.Size    = UDim2.new(0,0,1,0)
                obbyPctLbl.Text  = "0%"
            end
        end
    end)
end

obbyStartBtn.MouseButton1Click:Connect(function()
    if obbyFarming then stopObby() else startObby() end
end)

