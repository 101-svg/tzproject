                obbyEarned += 5
                earnedV.Text = "$"..obbyEarned
                logLine(obbyLog, "$5 reward! Total $"..obbyEarned, GOLD)
                updateBal()
            end
        end)
    end

    obbyThread = task.spawn(function()
        local total = #CHECKPOINTS
        while obbyFarming do
            obbyRuns += 1
            runsV.Text = tostring(obbyRuns)
            logLine(obbyLog, "Run #"..obbyRuns, CYAN)
            for i, cp in ipairs(CHECKPOINTS) do
                if not obbyFarming then break end
                local char = player.Character
                local hrp  = char and char:FindFirstChild("HumanoidRootPart")
                if hrp then hrp.CFrame = CFrame.new(cp.pos+Vector3.new(0,3,0)) end
                local pct = i/total
                TS:Create(obbyFill, TweenInfo.new(OBBY_DELAY*0.8),
                    {Size=UDim2.new(pct,0,1,0)}):Play()
                obbyStep.Text = "Checkpoint "..i.." / "..total.."  ["..cp.name.."]"
                obbyPct.Text  = math.floor(pct*100).."%"
                task.wait(OBBY_DELAY)
            end
            if obbyFarming then
                obbyFill.Size  = UDim2.new(1,0,1,0)
                obbyStep.Text  = "Waiting for reset..."
                obbyPct.Text   = "done"
                task.wait(LOOP_DELAY)
                obbyFill.Size  = UDim2.new(0,0,1,0)
                obbyPct.Text   = "0%"
            end
        end
    end)
end

obbyBtn2.MouseButton1Click:Connect(function()
    if obbyFarming then stopObby() else startObby() end
end)

-- balance poll
task.spawn(function()
    while gui.Parent do updateBal() task.wait(3) end
end)

