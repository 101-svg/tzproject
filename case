local function getBalance()
    local ok, v = pcall(function() return player.PlayerData.Currencies.Balance.Value end)
    return ok and v or 0
end

local function updateBalance()
    local bal = getBalance()
    tween(balLbl, {TextColor3 = C.green}, 0.1)
    balLbl.Text = "$"..string.format("%.2f", bal)
end

local function getItemValue(name, wear)
    local e = ITEM_VALUES[name]
    return e and (e[wear] or 0) or 0
end

local function getBankSnap()
    local snap = {}
    local bank = player.PlayerData:FindFirstChild("Bank")
    if not bank then return snap end
    for _, item in ipairs(bank:GetChildren()) do
        local uuid = item:GetAttribute("UUID")
        if uuid then snap[uuid] = true end
    end
    return snap
end

local function getNewItems(snap)
    local new = {}
    local bank = player.PlayerData:FindFirstChild("Bank")
    if not bank then return new end
    for _, item in ipairs(bank:GetChildren()) do
        local uuid = item:GetAttribute("UUID")
        if uuid and not snap[uuid] then
            table.insert(new, {
                Name     = item.Name,
                Wear     = item:GetAttribute("Wear") or "",
                Stattrak = item:GetAttribute("Stattrak") == true,
                Age      = item:GetAttribute("TimeObtained") or 0,
                UUID     = uuid,
            })
        end
    end
    return new
end

-- FIXED: use Name field, confirmed working format
local function sellItems(items)
    if #items == 0 then return 0 end
    local payload = {}
    for _, item in ipairs(items) do
        table.insert(payload, {
            Name     = item.Name,
            Wear     = item.Wear,
            Stattrak = item.Stattrak,
            Age      = item.Age,
            UUID     = item.UUID,
        })
    end
    local ok, res = pcall(function()
        return sellRemote:InvokeServer(payload)
    end)
    return (ok and res ~= nil) and #items or 0
end

-- ============================================================
-- SELL TRASH
-- ============================================================
local totalSoldCount = 0

local function sellAllTrash()
    local bank = player.PlayerData:FindFirstChild("Bank")
    if not bank then addLog(caseLog, "No bank found", C.red) return end
    local toSell = {}
    for _, item in ipairs(bank:GetChildren()) do
        if not item:GetAttribute("Escrow") and not item:GetAttribute("Locked") then
            if getItemValue(item.Name, item:GetAttribute("Wear") or "") < KEEP_THRESHOLD then
                table.insert(toSell, {
                    Name     = item.Name,
                    Wear     = item:GetAttribute("Wear") or "",
                    Stattrak = item:GetAttribute("Stattrak") == true,
                    Age      = item:GetAttribute("TimeObtained") or 0,
                    UUID     = item:GetAttribute("UUID"),
                })
            end
        end
    end
    if #toSell == 0 then
        addLog(caseLog, "Nothing to sell", C.muted)
        return
    end
    local sold = sellItems(toSell)
    totalSoldCount += sold
    soldVal.Text = tostring(totalSoldCount)
    addLog(caseLog, "Sold "..sold.." trash items", C.orange)
    updateBalance()
end

sellTrashBtn.MouseButton1Click:Connect(function() task.spawn(sellAllTrash) end)

