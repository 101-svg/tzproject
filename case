-- CASE FARM
-- ============================================================
local caseFarming = false
local caseThread  = nil
local nOpened, nKept = 0, 0

local function stopCase()
    caseFarming = false
    if caseThread then task.cancel(caseThread) caseThread=nil end
    caseBtn2.Text = "START FARMING"
    TS:Create(caseBtn2, TweenInfo.new(0.2), {BackgroundColor3=CYAN}):Play()
    cdLbl.Text = "Stopped"
    cdFill.Size = UDim2.new(0,0,1,0)
    cdTime.Text = ""
end

local function startCase()
    caseFarming = true
    caseBtn2.Text = "STOP FARMING"
    TS:Create(caseBtn2, TweenInfo.new(0.2), {BackgroundColor3=RED}):Play()
    caseBtn2.TextColor3 = TEXT
    logLine(caseLog, "Started -- Group case x"..BATCH, GREEN)

    caseThread = task.spawn(function()
        while caseFarming do
            local snap = bankSnap()
            cdLbl.Text = "Opening..."
            cdTime.Text = ""

            local ok, err = pcall(function()
                openCase:InvokeServer("Group", BATCH, false, false)
            end)

            if not ok then
                logLine(caseLog, "Failed: "..tostring(err), RED)
                task.wait(COOLDOWN)
            else
                nOpened += BATCH
                openedV.Text = tostring(nOpened)
                task.wait(0.15)

                local drops = newItems(snap)
                local toSell = {}
                for _, it in ipairs(drops) do
                    local v = itemVal(it.Name, it.Wear)
                    if v >= KEEP_MIN then
                        nKept += 1
                        keptV.Text = tostring(nKept)
                        logLine(caseLog, "KEPT  "..it.Name.."  $"..string.format("%.2f",v),
                            v>=1.5 and GOLD or GREEN)
                        addKeep(it.Name, it.Wear, v)
                    else
                        table.insert(toSell, it)
                    end
                end
                if #toSell > 0 then
                    local sold = sellItems(toSell)
                    totalSold += sold
                    soldV.Text = tostring(totalSold)
                end
                updateBal()

                -- cooldown bar
                local t0 = os.clock()
                while caseFarming and (os.clock()-t0) < COOLDOWN do
                    local pct = (os.clock()-t0)/COOLDOWN
                    local rem = COOLDOWN-(os.clock()-t0)
                    TS:Create(cdFill, TweenInfo.new(0.05), {Size=UDim2.new(pct,0,1,0)}):Play()
                    cdLbl.Text  = "Next open in"
                    cdTime.Text = string.format("%.1fs", rem)
                    task.wait(0.05)
                end
                cdFill.Size = UDim2.new(1,0,1,0)
                cdTime.Text = ""
            end
        end
    end)
end

caseBtn2.MouseButton1Click:Connect(function()
    if caseFarming then stopCase() else startCase() end
end)

