local function addKeepRow(itemId, wear, val)
    local lbl = Instance.new("TextLabel")
    lbl.Size, lbl.BackgroundTransparency = UDim2.new(1,-4,0,16), 1
    lbl.TextColor3             = val >= 1.5 and Color3.fromRGB(255,215,0) or Color3.fromRGB(100,255,100)
    lbl.TextSize, lbl.Font     = 10, Enum.Font.GothamBold
    lbl.TextXAlignment         = Enum.TextXAlignment.Left
    lbl.Text                   = string.format("[+] %s (%s) $%.2f", itemId, wear, val)
    lbl.Parent                 = keepScroll
    keepScroll.CanvasSize      = UDim2.new(0,0,0, #keepScroll:GetChildren()*17)
    keepScroll.CanvasPosition  = Vector2.new(0, math.huge)
end

local function getBalance()
    local ok, v = pcall(function() return player.PlayerData.Currencies.Balance.Value end)
    return ok and v or 0
end

local function updateBalance()
    balLabel.Text = string.format("Balance: $%.2f", getBalance())
end

local function getItemValue(itemId, wear)
    local entry = ITEM_VALUES[itemId]
    return entry and (entry[wear] or 0) or 0
end

local function getBankSnapshot()
    local snap = {}
    local bank = player.PlayerData:FindFirstChild("Bank")
    if not bank then return snap end
    for _, item in ipairs(bank:GetChildren()) do
        local uuid = item:GetAttribute("UUID")
        if uuid then snap[uuid] = true end
    end
    return snap
end

local function getNewItems(snapshot)
    local new = {}
    local bank = player.PlayerData:FindFirstChild("Bank")
    if not bank then return new end
    for _, item in ipairs(bank:GetChildren()) do
        local uuid = item:GetAttribute("UUID")
        if uuid and not snapshot[uuid] then
            table.insert(new, {
                Name     = item.Name,
                Wear     = item:GetAttribute("Wear") or "",
                Stattrak = item:GetAttribute("Stattrak") == true,
                Age      = item:GetAttribute("TimeObtained") or 0,
                UUID     = uuid,
            })
        end
    end
    return new
end

-- FIXED sell format: Name (not ItemId), matches confirmed working script
local function sellItems(items)
    if #items == 0 then return 0 end
    local payload = {}
    for _, item in ipairs(items) do
        table.insert(payload, {
            Name     = item.Name,
            Wear     = item.Wear,
            Stattrak = item.Stattrak,
            Age      = item.Age,
            UUID     = item.UUID,
        })
    end
    local ok, result = pcall(function()
        return sellRemote:InvokeServer(payload)
    end)
    return (ok and result ~= nil) and #items or 0
end

-- ============================================================
-- SELL ALL TRASH
-- ============================================================
local function sellAllTrash()
    local bank = player.PlayerData:FindFirstChild("Bank")
    if not bank then log("No bank found") return end
    local toSell = {}
    for _, item in ipairs(bank:GetChildren()) do
        if not item:GetAttribute("Escrow") and not item:GetAttribute("Locked") then
            local val = getItemValue(item.Name, item:GetAttribute("Wear") or "")
            if val < KEEP_THRESHOLD then
                table.insert(toSell, {
                    Name     = item.Name,
                    Wear     = item:GetAttribute("Wear") or "",
                    Stattrak = item:GetAttribute("Stattrak") == true,
                    Age      = item:GetAttribute("TimeObtained") or 0,
                    UUID     = item:GetAttribute("UUID"),
                })
            end
        end
    end
    if #toSell == 0 then log("Nothing to sell", Color3.fromRGB(150,150,150)) return end
    local sold = sellItems(toSell)
    log("Sold " .. sold .. " trash items", Color3.fromRGB(200,200,80))
    updateBalance()
end

-- ============================================================
-- CASE FARM LOOP
-- ============================================================
local farming    = false
local farmThread = nil
local totalOpened = 0
local totalKept   = 0

local function stopFarming()
    farming = false
    if farmThread then task.cancel(farmThread) farmThread = nil end
    startBtn.Text             = "> START FARMING"
    startBtn.BackgroundColor3 = Color3.fromRGB(30,130,30)
    cdLabel.Text              = "stopped"
    cdBar.Size                = UDim2.new(0,0,1,0)
    log("Stopped -- " .. totalOpened .. " opened, " .. totalKept .. " kept", Color3.fromRGB(200,200,100))
end

local function startFarming()
    farming     = true
    totalOpened = 0
    totalKept   = 0
    startBtn.Text             = "[] STOP"
    startBtn.BackgroundColor3 = Color3.fromRGB(130,30,30)
    log("Started -- Group case, keeping $" .. KEEP_THRESHOLD .. "+", Color3.fromRGB(100,255,100))

    farmThread = task.spawn(function()
        while farming do
            local before = getBankSnapshot()
            local ok, err = pcall(function()
                openCase:InvokeServer("Group", BATCH_SIZE, false, false)
            end)
            if not ok then
                log("Open failed: " .. tostring(err), Color3.fromRGB(255,100,100))
                task.wait(COOLDOWN)
            else
                totalOpened += BATCH_SIZE
                task.wait(0.15)
                local newItems = getNewItems(before)
                local sellList = {}
                for _, item in ipairs(newItems) do
                    local val = getItemValue(item.Name, item.Wear)
                    if val >= KEEP_THRESHOLD then
                        totalKept += 1
                        addKeepRow(item.Name, item.Wear, val)
                        log("KEEP " .. item.Name .. " $" .. string.format("%.2f", val),
                            val >= 1.5 and Color3.fromRGB(255,215,0) or Color3.fromRGB(100,255,100))
                    else
                        table.insert(sellList, item)
                    end
                end
                if #sellList > 0 then sellItems(sellList) end
                statsLabel.Text = totalOpened .. " opened | " .. totalKept .. " kept"
                updateBalance()
                local start = os.clock()
                while farming and (os.clock()-start) < COOLDOWN do
                    local pct = (os.clock()-start)/COOLDOWN
                    cdBar.Size   = UDim2.new(pct,0,1,0)
                    cdLabel.Text = string.format("cooldown: %.1fs", COOLDOWN-(os.clock()-start))
                    task.wait(0.05)
                end
                cdBar.Size   = UDim2.new(1,0,1,0)
                cdLabel.Text = "opening..."
            end
        end
    end)
end

startBtn.MouseButton1Click:Connect(function()
    if farming then stopFarming() else startFarming() end
end)
sellBtn.MouseButton1Click:Connect(function() task.spawn(sellAllTrash) end)

