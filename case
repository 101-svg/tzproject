local function switchTab(idx)
    for i, p in ipairs(panels) do
        p.Visible = (i == idx)
    end
    for i, t in ipairs(tabFrames) do
        local active = (i == idx)
        tween(t, {BackgroundTransparency = active and 0 or 1}, 0.2)
        tabLabels[i].TextColor3 = active and Color3.fromRGB(5,10,20) or C.muted
        if active then
            gradient(t, C.accent, Color3.fromRGB(99,179,237), 90)
        end
    end
end

