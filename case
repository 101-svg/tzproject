local function log(text, color)
    local kids = logScroll:GetChildren()
    if #kids > 82 then
        for i = 1, #kids-80 do
            if kids[i]:IsA("TextLabel") then kids[i]:Destroy() end
        end
    end
    local lbl = Instance.new("TextLabel")
    lbl.Size, lbl.BackgroundTransparency = UDim2.new(1,-4,0,14), 1
    lbl.TextColor3             = color or Color3.fromRGB(170,170,170)
    lbl.TextSize, lbl.Font     = 10, Enum.Font.Gotham
    lbl.TextXAlignment         = Enum.TextXAlignment.Left
    lbl.TextTruncate           = Enum.TextTruncate.AtEnd
    lbl.Text                   = os.date("%H:%M:%S") .. " " .. text
    lbl.Parent                 = logScroll
    logScroll.CanvasSize       = UDim2.new(0,0,0, #logScroll:GetChildren()*15)
    logScroll.CanvasPosition   = Vector2.new(0, math.huge)
end

