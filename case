local function getBalance()
    local ok, v = pcall(function() return player.PlayerData.Currencies.Balance.Value end)
    return ok and v or 0
end
local function updateBal()
    balLbl.Text = "$"..string.format("%.2f", getBalance())
end

local function itemVal(name, wear)
    local e = ITEM_VALUES[name]
    return e and (e[wear] or 0) or 0
end

local function bankSnap()
    local snap = {}
    local bank = player.PlayerData:FindFirstChild("Bank")
    if bank then for _, i in ipairs(bank:GetChildren()) do
        local u = i:GetAttribute("UUID")
        if u then snap[u]=true end
    end end
    return snap
end

local function newItems(snap)
    local new = {}
    local bank = player.PlayerData:FindFirstChild("Bank")
    if bank then for _, i in ipairs(bank:GetChildren()) do
        local u = i:GetAttribute("UUID")
        if u and not snap[u] then
            table.insert(new, {
                Name     = i.Name,
                Wear     = i:GetAttribute("Wear") or "",
                Stattrak = i:GetAttribute("Stattrak")==true,
                Age      = i:GetAttribute("TimeObtained") or 0,
                UUID     = u,
            })
        end
    end end
    return new
end

-- FIXED sell: Name field matches confirmed working format
local totalSold = 0
local function sellItems(items)
    if #items==0 then return 0 end
    local payload = {}
    for _, it in ipairs(items) do
        table.insert(payload, {
            Name=it.Name, Wear=it.Wear,
            Stattrak=it.Stattrak, Age=it.Age, UUID=it.UUID
        })
    end
    local ok, res = pcall(function() return sellRemote:InvokeServer(payload) end)
    return (ok and res~=nil) and #items or 0
end

local function doSellTrash()
    local bank = player.PlayerData:FindFirstChild("Bank")
    if not bank then logLine(caseLog, "No bank found", RED) return end
    local toSell = {}
    for _, it in ipairs(bank:GetChildren()) do
        if not it:GetAttribute("Escrow") and not it:GetAttribute("Locked") then
            if itemVal(it.Name, it:GetAttribute("Wear") or "") < KEEP_MIN then
                table.insert(toSell, {
                    Name=it.Name, Wear=it:GetAttribute("Wear") or "",
                    Stattrak=it:GetAttribute("Stattrak")==true,
                    Age=it:GetAttribute("TimeObtained") or 0, UUID=it:GetAttribute("UUID")
                })
            end
        end
    end
    if #toSell==0 then logLine(caseLog,"Nothing below $"..KEEP_MIN,MUTED) return end
    local sold = sellItems(toSell)
    totalSold += sold
    soldV.Text = tostring(totalSold)
    logLine(caseLog, "Sold "..sold.." trash items", ORAN)
    updateBal()
end

sellBtn2.MouseButton1Click:Connect(function() task.spawn(doSellTrash) end)

