-- ============================================================
-- UI HELPERS
-- ============================================================
local function corner(parent, r)
    Instance.new("UICorner", parent).CornerRadius = UDim.new(0, r or 8)
end

local function stroke(parent, col, thickness)
    local s = Instance.new("UIStroke", parent)
    s.Color     = col or C.border
    s.Thickness = thickness or 1
    s.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
end

local function gradient(parent, c0, c1, rot)
    local g = Instance.new("UIGradient", parent)
    g.Color    = ColorSequence.new(c0, c1)
    g.Rotation = rot or 90
end

local function tween(obj, props, t, style, dir)
    TweenService:Create(obj,
        TweenInfo.new(t or 0.2, style or Enum.EasingStyle.Quad, dir or Enum.EasingDirection.Out),
        props):Play()
end

local function mkLabel(parent, text, size, color, font, xa)
    local l = Instance.new("TextLabel", parent)
    l.BackgroundTransparency = 1
    l.Text      = text
    l.TextSize  = size or 11
    l.TextColor3 = color or C.text
    l.Font      = font or Enum.Font.GothamBold
    l.TextXAlignment = xa or Enum.TextXAlignment.Left
    l.TextTruncate   = Enum.TextTruncate.AtEnd
    return l
end

local function mkFrame(parent, bg, trans)
    local f = Instance.new("Frame", parent)
    f.BackgroundColor3       = bg or C.surface
    f.BackgroundTransparency = trans or 0
    f.BorderSizePixel        = 0
    return f
end

local function mkBtn(parent, text, bg)
    local b = Instance.new("TextButton", parent)
    b.BackgroundColor3 = bg or C.accent
    b.BorderSizePixel  = 0
    b.TextColor3       = Color3.fromRGB(5,10,20)
    b.TextSize         = 12
    b.Font             = Enum.Font.GothamBold
    b.Text             = text
    b.AutoButtonColor  = false
    corner(b, 6)
    -- hover effect
    b.MouseEnter:Connect(function()
        tween(b, {BackgroundColor3 = Color3.fromRGB(
            math.min(255, bg and bg.R*255+30 or 120),
            math.min(255, bg and bg.G*255+30 or 220),
            math.min(255, bg and bg.B*255+20 or 270)
        )}, 0.15)
    end)
    b.MouseLeave:Connect(function()
        tween(b, {BackgroundColor3 = bg or C.accent}, 0.15)
    end)
    return b
end

local function mkBar(parent, y, h, col)
    local bg = mkFrame(parent, C.dim)
    bg.Size     = UDim2.new(1,-24,0,h or 5)
    bg.Position = UDim2.new(0,12,0,y)
    corner(bg, 3)
    local fill = mkFrame(bg, col or C.accent)
    fill.Size   = UDim2.new(0,0,1,0)
    corner(fill, 3)
    gradient(fill, col or C.accent, Color3.fromRGB(
        math.min(255,(col or C.accent).R*255+40),
        math.min(255,(col or C.accent).G*255+20),
        math.min(255,(col or C.accent).B*255+60)
    ), 90)
    return fill, bg
end

local function mkScroll(parent, y, h)
    local s = Instance.new("ScrollingFrame", parent)
    s.Size                   = UDim2.new(1,-24,0,h)
    s.Position               = UDim2.new(0,12,0,y)
    s.BackgroundTransparency = 1
    s.BorderSizePixel        = 0
    s.ScrollBarThickness     = 2
    s.ScrollBarImageColor3   = C.border
    s.CanvasSize             = UDim2.new(0,0,0,0)
    local layout = Instance.new("UIListLayout", s)
    layout.Padding           = UDim.new(0,3)
    return s
end

local function addLog(scroll, text, color)
    local kids = scroll:GetChildren()
    if #kids > 60 then
        for i=1, #kids-55 do
            if kids[i]:IsA("Frame") then kids[i]:Destroy() end
        end
    end
    local row = mkFrame(scroll, C.surface2)
    row.Size             = UDim2.new(1,0,0,18)
    corner(row, 4)
    local dot = mkFrame(row, color or C.muted)
    dot.Size, dot.Position = UDim2.new(0,4,0,7), UDim2.new(0,6,0,0)
    corner(dot, 2)
    local lbl = mkLabel(row, os.date("%H:%M:%S") .. "  " .. text, 10, color or C.muted)
    lbl.Size, lbl.Position = UDim2.new(1,-18,1,0), UDim2.new(0,16,0,0)
    scroll.CanvasSize = UDim2.new(0,0,0, #scroll:GetChildren()*21)
    scroll.CanvasPosition = Vector2.new(0, math.huge)
    print("[FarmAll] " .. text)
    return row
end

