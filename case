local caseFarming  = false
local caseThread   = nil
local totalOpened  = 0
local totalKept    = 0

local function stopCase()
    caseFarming = false
    if caseThread then task.cancel(caseThread) caseThread = nil end
    caseStartBtn.Text = "START FARMING"
    tween(caseStartBtn, {BackgroundColor3 = C.accent}, 0.3)
    cdLbl.Text = "Stopped"
    cdFill.Size = UDim2.new(0,0,1,0)
end

local function startCase()
    caseFarming = true
    caseStartBtn.Text = "STOP FARMING"
    tween(caseStartBtn, {BackgroundColor3 = C.red}, 0.3)
    addLog(caseLog, "Case farm started", C.green)

    caseThread = task.spawn(function()
        while caseFarming do
            local snap = getBankSnap()
            cdLbl.Text = "Opening..."
            local ok, err = pcall(function()
                openCase:InvokeServer("Group", BATCH_SIZE, false, false)
            end)
            if not ok then
                addLog(caseLog, "Failed: "..tostring(err), C.red)
                task.wait(COOLDOWN)
            else
                totalOpened += BATCH_SIZE
                openedVal.Text = tostring(totalOpened)
                task.wait(0.15)

                local newItems = getNewItems(snap)
                local toSell = {}
                for _, item in ipairs(newItems) do
                    local val = getItemValue(item.Name, item.Wear)
                    if val >= KEEP_THRESHOLD then
                        totalKept += 1
                        keptVal.Text = tostring(totalKept)
                        addLog(caseLog,
                            "KEPT  "..item.Name.."  $"..string.format("%.2f",val),
                            val >= 1.5 and C.gold or C.green)
                        addKeepEntry(item.Name, item.Wear, val)
                    else
                        table.insert(toSell, item)
                    end
                end
                if #toSell > 0 then
                    local sold = sellItems(toSell)
                    totalSoldCount += sold
                    soldVal.Text = tostring(totalSoldCount)
                end
                updateBalance()

                -- cooldown animation
                local t0 = os.clock()
                while caseFarming and (os.clock()-t0) < COOLDOWN do
                    local pct = (os.clock()-t0)/COOLDOWN
                    local rem = COOLDOWN-(os.clock()-t0)
                    tween(cdFill, {Size=UDim2.new(pct,0,1,0)}, 0.05)
                    cdLbl.Text  = "Next open in"
                    cdTimeLbl.Text = string.format("%.1fs", rem)
                    task.wait(0.05)
                end
                cdFill.Size    = UDim2.new(1,0,1,0)
                cdTimeLbl.Text = ""
            end
        end
    end)
end

caseStartBtn.MouseButton1Click:Connect(function()
    if caseFarming then stopCase() else startCase() end
end)

