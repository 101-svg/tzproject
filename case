local function frame(parent, size, pos, bg, trans)
    local f = Instance.new("Frame", parent)
    f.Size, f.Position       = size, pos
    f.BackgroundColor3       = bg or SURF
    f.BackgroundTransparency = trans or 0
    f.BorderSizePixel        = 0
    return f
end

local function corner(obj, r)
    Instance.new("UICorner", obj).CornerRadius = UDim.new(0, r or 8)
end

local function stroke(obj, col, t)
    local s = Instance.new("UIStroke", obj)
    s.Color, s.Thickness = col or DIM, t or 1
    s.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
end

local function label(parent, txt, size, col, font, xa)
    local l = Instance.new("TextLabel", parent)
    l.BackgroundTransparency = 1
    l.Text, l.TextSize       = txt, size or 11
    l.TextColor3             = col or TEXT
    l.Font                   = font or Enum.Font.GothamBold
    l.TextXAlignment         = xa or Enum.TextXAlignment.Left
    l.TextTruncate           = Enum.TextTruncate.AtEnd
    l.BorderSizePixel        = 0
    return l
end

local function btn(parent, txt, size, pos, bg, tc)
    local b = Instance.new("TextButton", parent)
    b.Size, b.Position     = size, pos
    b.BackgroundColor3     = bg or CYAN
    b.TextColor3           = tc or Color3.fromRGB(5,10,20)
    b.TextSize             = 12
    b.Font                 = Enum.Font.GothamBold
    b.Text                 = txt
    b.BorderSizePixel      = 0
    b.AutoButtonColor      = false
    corner(b, 7)
    b.MouseEnter:Connect(function()
        TS:Create(b, TweenInfo.new(0.12), {BackgroundTransparency=0.25}):Play()
    end)
    b.MouseLeave:Connect(function()
        TS:Create(b, TweenInfo.new(0.12), {BackgroundTransparency=0}):Play()
    end)
    return b
end

local function progressBar(parent, pos, col)
    local bg = frame(parent,
        UDim2.new(1,-24,0,6),
        UDim2.new(0,12,0,pos),
        DIM)
    corner(bg, 3)
    local fill = frame(bg, UDim2.new(0,0,1,0), UDim2.new(0,0,0,0), col or CYAN)
    corner(fill, 3)
    return fill
end

local function scrollArea(parent, pos, h)
    local s = Instance.new("ScrollingFrame", parent)
    s.Size, s.Position       = UDim2.new(1,-24,0,h), UDim2.new(0,12,0,pos)
    s.BackgroundTransparency = 1
    s.BorderSizePixel        = 0
    s.ScrollBarThickness     = 2
    s.ScrollBarImageColor3   = DIM
    s.CanvasSize             = UDim2.new(0,0,0,0)
    Instance.new("UIListLayout", s).Padding = UDim.new(0,3)
    return s
end

local function logLine(scroll, txt, col)
    local kids = scroll:GetChildren()
    if #kids > 70 then
        for i=1, #kids-65 do
            if kids[i]:IsA("Frame") then kids[i]:Destroy() end
        end
    end
    local row = frame(scroll, UDim2.new(1,0,0,20), UDim2.new(0,0,0,0), SURF2)
    corner(row, 5)
    local dot = frame(row, UDim2.new(0,5,0,5), UDim2.new(0,6,0,7), col or MUTED)
    corner(dot, 3)
    local lbl = label(row, os.date("%H:%M ")..txt, 10, col or MUTED, Enum.Font.Gotham)
    lbl.Size, lbl.Position = UDim2.new(1,-20,1,0), UDim2.new(0,18,0,0)
    scroll.CanvasSize     = UDim2.new(0,0,0, #scroll:GetChildren()*23)
    scroll.CanvasPosition = Vector2.new(0, math.huge)
    print("[FA] "..txt)
end

