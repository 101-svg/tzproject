    TS:Create(obbyBtn2, TweenInfo.new(0.2), {BackgroundColor3=RED}):Play()
    obbyBtn2.TextColor3 = TEXT
    logLine(obbyLog, "Obby started -- "..OBBY_DELAY.."s/checkpoint", GREEN)

    local notifyR = RS:FindFirstChild("Remotes") and RS.Remotes:FindFirstChild("Notify")
    if notifyR then
        if rewardConn then rewardConn:Disconnect() end
        rewardConn = notifyR.OnClientEvent:Connect(function(msg)
