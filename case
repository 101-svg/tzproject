local obbyRunning  = false
local obbyThread   = nil
local totalEarned  = 0
local runCount     = 0
local rewardConn   = nil

local function stopObby()
    obbyRunning = false
    if obbyThread then task.cancel(obbyThread) obbyThread = nil end
    obbyStartBtn.Text             = "> START"
    obbyStartBtn.BackgroundColor3 = Color3.fromRGB(30,130,30)
    statusLabel.Text              = "stopped"
    bar.Size                      = UDim2.new(0,0,1,0)
end

local function startObby()
    obbyRunning = true
    runCount    = 0
    obbyStartBtn.Text             = "[] STOP"
    obbyStartBtn.BackgroundColor3 = Color3.fromRGB(130,30,30)

    -- watch for reward
    local notifyRemote = RS:FindFirstChild("Remotes") and RS.Remotes:FindFirstChild("Notify")
    if notifyRemote then
        if rewardConn then rewardConn:Disconnect() end
        rewardConn = notifyRemote.OnClientEvent:Connect(function(msg)
            if type(msg)=="string" and msg:lower():find("obby") then
                totalEarned += 5
                earnLabel.Text = "Total earned: $" .. totalEarned
                obbyLog("$5 awarded! Total: $" .. totalEarned, Color3.fromRGB(255,215,0))
                updateBalance()
            end
        end)
    end

    obbyThread = task.spawn(function()
        local total = #CHECKPOINTS
        while obbyRunning do
            runCount += 1
            obbyLog("Run #" .. runCount .. " starting...", Color3.fromRGB(100,220,100))
            statusLabel.Text = "run #" .. runCount

            for i, cp in ipairs(CHECKPOINTS) do
                if not obbyRunning then break end
                local char = player.Character
                local hrp  = char and char:FindFirstChild("HumanoidRootPart")
                if hrp then hrp.CFrame = CFrame.new(cp.pos + Vector3.new(0,3,0)) end
                checkLabel.Text = "checkpoint " .. i .. " / " .. total .. "  [" .. cp.name .. "]"
                bar.Size        = UDim2.new(i/total, 0, 1, 0)
                statusLabel.Text = "run #" .. runCount .. " -- cp " .. cp.name
                obbyLog("Touched " .. cp.name, i==total and Color3.fromRGB(255,215,0) or Color3.fromRGB(140,140,140))
                task.wait(STEP_DELAY)
            end

            if obbyRunning then
                bar.Size                 = UDim2.new(1,0,1,0)
                bar.BackgroundColor3     = Color3.fromRGB(255,215,0)
                statusLabel.Text         = "run #" .. runCount .. " -- waiting for reset..."
                task.wait(LOOP_DELAY)
                bar.BackgroundColor3     = Color3.fromRGB(50,200,50)
                bar.Size                 = UDim2.new(0,0,1,0)
            end
        end
    end)
end

obbyStartBtn.MouseButton1Click:Connect(function()
    if obbyRunning then stopObby() else startObby() end
end)

